{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Kitty Tools",
  "version": "0.1.3",
  "identifier": "com.yy.kitty-tools",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: blob: asset: http://asset.localhost; style-src 'self' 'unsafe-inline'; connect-src https: http:",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPDATA/clipboard_images/*"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "infoPlist": "Info.plist"
    },
    "windows": {
      "wix": {
        "language": "zh-CN"
      },
      "nsis": {
        "languages": [
          "simpchinese",
          "english"
        ]
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IERBNzdGQzg0MTFFQkIxMzcKUldRM3Nlc1JoUHgzMmpTVk1qOTFFOXA0aUpHMkpkOEZrMjhXY0NXR2pmcjN5cW5RSDlnNUs2enQK",
      "endpoints": [
        "https://api.gitcode.com/api/v5/repos/yyandbug/kitty-tools/releases/latest/attach_files/latest.json/download"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
