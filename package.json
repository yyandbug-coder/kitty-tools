{
  "name": "kitty-tools",
  "private": true,
  "version": "0.1.2",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "check": "pnpm exec tsc --noEmit && pnpm build",
    "check:rust": "cd src-tauri && cargo clippy --all-targets -- -D warnings && cargo test",
    "analyze": "tsc && vite build --mode analyze",
    "preview": "vite preview",
    "tauri": "tauri",
    "release": "node scripts/updater-skill.mjs release-interactive.mjs",
    "release:interactive": "node scripts/updater-skill.mjs release-interactive.mjs",
    "create:release": "node scripts/updater-skill.mjs release-interactive.mjs",
    "release:cli": "node scripts/updater-skill.mjs release.mjs",
    "release:publish": "node scripts/updater-skill.mjs release.mjs --publish",
    "release:dry-run": "node scripts/updater-skill.mjs release.mjs --dry-run",
    "release:upload": "node scripts/updater-skill.mjs gitcode-upload-release.mjs",
    "release:json": "node scripts/updater-skill.mjs generate-latest-json.mjs"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.8",
    "@tanstack/react-virtual": "^3.13.23",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-autostart": "^2.5.1",
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "@tauri-apps/plugin-fs": "^2.5.0",
    "@tauri-apps/plugin-global-shortcut": "^2.3.1",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-sql": "^2.4.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.20",
    "lucide-react": "^1.8.0",
    "radix-ui": "^1.4.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-hot-toast": "^2.6.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "vanilla-jsoneditor": "^3.12.0"
  },
  "devDependencies": {
    "@clack/prompts": "^1.5.1",
    "@tailwindcss/vite": "^4.2.2",
    "@tauri-apps/cli": "^2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "tailwindcss": "^4.2.2",
    "tauri-release-utils": "^0.1.1",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "vite-plugin-svg-icons-ng": "^1.7.0"
  }
}
